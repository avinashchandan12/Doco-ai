%%{init: {'theme':'base'}}%%

flowchart TB
    Start(["👨‍⚕️<br/>START<br/>Doctor Login"])
    
    %% PHASE 1: DATA COLLECTION (Top Right Quadrant)
    P1["📝 PHASE 1<br/>DATA COLLECTION"]
    Patient["Patient Details<br/>+ ABHA Scan"]
    Symptoms["Symptoms Entry<br/>Voice/Text"]
    Vitals["Record Vitals<br/>+ Prescription OCR"]
    
    %% PHASE 2: AI PROCESSING (Bottom Right Quadrant)
    P2["🤖 PHASE 2<br/>AI PROCESSING"]
    Analysis["Clinical Analysis<br/>3 Seconds"]
    Outbreak["Outbreak Detection<br/>Pattern Recognition"]
    DrugCheck["Drug Safety<br/>Interaction Check"]
    
    %% PHASE 3: RESULTS (Bottom Left Quadrant)
    P3["📋 PHASE 3<br/>RESULTS & ALERTS"]
    Results["Clinical Summary<br/>Diagnosis • Red Flags"]
    VillageAlert["🚨 Village Alert<br/>If Outbreak Detected"]
    
    %% PHASE 4: ACTION (Top Left Quadrant)
    P4["👨‍⚕️ PHASE 4<br/>DOCTOR ACTION"]
    Review["Review & Prescribe"]
    Generic["Generic Alternatives<br/>Jan Aushadhi"]
    SaveReport["Save & Report<br/>PDF/SMS/Email"]
    
    %% PHASE 5: LEARNING (Center to Start)
    P5["🔄 PHASE 5<br/>CONTINUOUS LEARNING"]
    Feedback["Doctor Feedback<br/>AI Improves"]
    
    End(["✅<br/>COMPLETE<br/>Next Case"])
    
    %% Circular Flow
    Start --> P1
    P1 --> Patient
    Patient --> Symptoms
    Symptoms --> Vitals
    
    Vitals --> P2
    P2 --> Analysis
    Analysis --> Outbreak
    Outbreak --> DrugCheck
    
    DrugCheck --> P3
    P3 --> Results
    Results --> VillageAlert
    
    VillageAlert --> P4
    P4 --> Review
    Review --> Generic
    Generic --> SaveReport
    
    SaveReport --> P5
    P5 --> Feedback
    Feedback --> End
    
    End -.Next Patient.-> Start
    
    %% Styling
    classDef phase fill:#64748b,stroke:#475569,stroke-width:3px,color:#fff,font-weight:bold,font-size:14px
    classDef start fill:#10b981,stroke:#059669,stroke-width:4px,color:#fff,font-weight:bold,font-size:16px
    classDef input fill:#3b82f6,stroke:#2563eb,stroke-width:2px,color:#fff
    classDef ai fill:#8b5cf6,stroke:#7c3aed,stroke-width:2px,color:#fff
    classDef result fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#000
    classDef action fill:#14b8a6,stroke:#0d9488,stroke-width:2px,color:#fff
    classDef learn fill:#ec4899,stroke:#db2777,stroke-width:2px,color:#fff
    classDef alert fill:#ef4444,stroke:#dc2626,stroke-width:3px,color:#fff,font-weight:bold
    
    class P1,P2,P3,P4,P5 phase
    class Start,End start
    class Patient,Symptoms,Vitals input
    class Analysis,Outbreak,DrugCheck ai
    class Results result
    class VillageAlert alert
    class Review,Generic,SaveReport action
    class Feedback learn
